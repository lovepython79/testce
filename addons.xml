<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="repository.ce-il" name="coreELEC-IL Repository" version="1.0.1"
    provider-name="coreELEC-IL">
    <extension point="xbmc.addon.repository" name="coreELEC-IL Repository">
        <dir>
    <info compressed="false">https://raw.githubusercontent.com/lovepython79/coreelec-il/main/addons.xml</info>
    <checksum>https://raw.githubusercontent.com/lovepython79/coreelec-il/main/addons.xml.md5</checksum>
    <datadir zip="true">https://raw.githubusercontent.com/lovepython79/coreelec-il/main/zips</datadir>
</dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">The Official coreELEC-IL Community Repository</summary>
        <description lang="en_GB">Install addons from coreELEC-IL</description>
        <summary lang="he_IL">המאגר הרשמי של קהילת coreELEC-IL</summary>
        <description lang="he_IL">התקנת הרחבות מבית coreELEC-IL</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

<addon id="plugin.program.autocompletion.ce-il"
    name="AutoCompletion for virtual keyboard (Hebrew) [coreELEC-IL]" version="3.0.0"
    provider-name="Philipp Temminghoff (phil65), sualfred, xulek, finkleandeinhorn,(lovepython79) - [coreELEC-IL]">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="script.module.autocompletion.ce-il" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.script" library="plugin.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">AutoCompletion for the virtual keyboard (coreELEC-IL Edition)</summary>
        <description lang="en_GB">
            AutoCompletion for the virtual keyboard. Optimized for the [coreELEC-IL] community with
            Hebrew RTL support.
            Original Authors: Philipp Temminghoff (phil65), sualfred, xulek, finkleandeinhorn.
            Hebrew RTL fix and maintenance by (lovepython79) for the [coreELEC-IL] community.
        </description>
        <summary lang="he_IL">השלמה אוטומטית למקלדת (גרסת coreELEC-IL) (lovepython79)</summary>
        <description lang="he_IL">
            השלמה אוטומטית למקלדת הווירטואלית.
            גרסה זו מותאמת למשתמשי [coreELEC-IL] וכוללת תיקון מובנה לבעיית היפוך האותיות (RTL)
            בתוצאות החיפוש בעברית.
            יוצרים מקוריים: Philipp Temminghoff (phil65), sualfred, xulek, finkleandeinhorn.
            תיקון עברית ותחזוקה: (lovepython79) עבור קהילת [coreELEC-IL].
        </description>
        <platform>all</platform>
        <license>GPL-2.0-or-later</license>
        <source>https://github.com/lovepython79/coreelec-il</source>
        <assets>
            <icon>resources/icon.png</icon>
            <screenshot>resources/screenshot-01.jpg</screenshot>
            <screenshot>resources/screenshot-02.jpg</screenshot>
            <screenshot>resources/screenshot-03.jpg</screenshot>
        </assets>
    </extension>
</addon>

<addon id="script.module.autocompletion.ce.il" name="AutoCompletion library [CoreELEC-IL] (lovepython79)"
    version="3.0.0" provider-name="Philipp Temminghoff (phil65), (lovepython79) - [CoreELEC-IL]">
    <requires>
        <!--[coreELEC-IL]-->
        <!--Removed unused import -->
        <!--Previous version: 2.24.0-->
        <import addon="xbmc.python" version="3.0.0" />
        <!--Previous version: 2.9.1 -->
        <import addon="script.module.requests" version="2.31.0" />
    </requires>
    <extension point="xbmc.python.module" library="lib" />
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Module providing AutoCompletion functions (CoreELEC-IL Edition)</summary>
        <description lang="en_GB">
            Module providing AutoCompletion functions for Kodi keyboards.
            Original Author: Philipp Temminghoff (phil65).
            Modified with Hebrew RTL support and maintained by (lovepython79) for the [CoreELEC-IL]
            community.
        </description>
        <summary lang="he_IL">מודול השלמה אוטומטית [CoreELEC-IL] (lovepython79)</summary>
        <description lang="he_IL">
            מודול המספק פונקציות להשלמה אוטומטית במקלדות של קודי.
            יוצר מקורי: Philipp Temminghoff (phil65).
            גרסה זו כוללת תיקון RTL (היפוך טקסט) לעברית ותחזוקה על ידי (lovepython79) עבור קהילת
            [CoreELEC-IL].
        </description>

        <platform>all</platform>
        <license>GPL-2.0-or-later</license>
        <source>https://github.com/lovepython79/coreelec-il</source>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
</addons>
