<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="repository.ce-il" name="coreELEC-IL Repository" version="1.0.1" provider-name="coreELEC-IL">
        <extension point="xbmc.addon.repository" name="coreELEC-IL Repository">
            <dir>
                <info compressed="false">https://raw.githubusercontent.com/lovepython79/coreelec-il/main/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/lovepython79/coreelec-il/main/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/lovepython79/coreelec-il/main/zips</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">The Official coreELEC-IL Community Repository</summary>
            <description lang="en_GB">Install addons from coreELEC-IL</description>
            <summary lang="he_IL">המאגר הרשמי של קהילת coreELEC-IL</summary>
            <description lang="he_IL">התקנת הרחבות מבית coreELEC-IL</description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>

    <addon id="plugin.program.autocompletion.ce-il" name="AutoCompletion for virtual keyboard (Hebrew) [coreELEC-IL]" version="3.0.0" provider-name="coreELEC-IL">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="script.module.autocompletion.ce-il" version="3.0.0" />
        </requires>
        <extension point="xbmc.python.script" library="plugin.py">
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="he_IL">השלמה אוטומטית למקלדת (גרסת coreELEC-IL)</summary>
            <description lang="he_IL">השלמה אוטומטית למקלדת הווירטואלית עם תיקון מובנה לבעיית היפוך האותיות (RTL) בחיפוש בעברית.</description>
            <news lang="he_IL">[v3.0.0] הסבה מלאה ל-Python 3, תמיכה ב-Kodi 21 ותיקוני RTL לעברית.</news>
            <platform>all</platform>
            <license>GPL-2.0-or-later</license>
            <source>https://github.com/lovepython79/coreelec-il</source>
            <assets>
                <icon>resources/icon.png</icon>
                <screenshot>resources/screenshot-01.jpg</screenshot>
            </assets>
        </extension>
    </addon>

    <addon id="script.module.autocompletion.ce-il" name="AutoCompletion library [CoreELEC-IL]" version="3.0.0" provider-name="coreELEC-IL">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="script.module.requests" version="2.31.0" />
        </requires>
        <extension point="xbmc.python.module" library="lib" />
        <extension point="xbmc.addon.metadata">
            <summary lang="he_IL">מודול השלמה אוטומטית [CoreELEC-IL]</summary>
            <description lang="he_IL">מודול המספק פונקציות להשלמה אוטומטית במקלדות של קודי עם תמיכה ב-RTL.</description>
            <platform>all</platform>
            <license>GPL-2.0-or-later</license>
            <source>https://github.com/lovepython79/coreelec-il</source>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>
</addons>
